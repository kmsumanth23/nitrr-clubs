# Supabase — fill these at step 2 (Project Settings → API)
# Copy this file to .env.local and paste your real values. Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Bypasses RLS — used only in trusted server code, never sent to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
